{
	"compilerOptions": {
		"target": "ESNext",
		"module": "NodeNext",
		"moduleResolution": "NodeNext",
		"esModuleInterop": true,
		"skipLibCheck": true,
		"strict": true,
		"forceConsistentCasingInFileNames": true,
		"outDir": "./dist",
		"paths": {
			"@pokedex/shared/*": ["../shared/*"]
		}
	},
	"include": ["src/**/*"]
}
