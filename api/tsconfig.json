{
	"compilerOptions": {
		"target": "ESNext",
		"module": "NodeNext",
		"moduleResolution": "NodeNext",
		"esModuleInterop": true,
		"skipLibCheck": true,
		"strict": true,
		"forceConsistentCasingInFileNames": true,
		"outDir": "./dist",
		"typeRoots": ["./node_modules/@types", "./src/types"],
		"paths": {
			"@pokedex/shared/*": ["../shared/*"]
		}
	},
	"include": ["src/**/*", "src/types/express.d.ts"]
}
